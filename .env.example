# ========================================
# Duke ML Chatbot - Environment Variables
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ========================================
# Azure AI Foundry Credentials (Required)
# ========================================
# Your Azure AI Foundry endpoint URL (any of the three formats work):
#   https://YOUR-RESOURCE.openai.azure.com/
#   https://YOUR-RESOURCE.services.ai.azure.com/
#   https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Your API key from Azure AI Foundry
AZURE_OPENAI_API_KEY=your-api-key-here

# ========================================
# Model Configuration
# ========================================
# The model deployment name to use
MODEL_NAME=gpt-5.2

# Reasoning effort: "low", "medium", or "high"
# Lower = faster + cheaper, Higher = more thorough
REASONING_EFFORT=low

# ========================================
# Chatbot Personality (Optional)
# ========================================
# System instructions that shape the chatbot's behavior
CHATBOT_INSTRUCTIONS=You are a helpful assistant. Be concise and friendly.

# Flask debug mode (set to 1 only for local development)
FLASK_DEBUG=0
